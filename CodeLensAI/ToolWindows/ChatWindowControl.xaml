<UserControl x:Class="CodeLensAI.ToolWindows.ChatWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="360"
             Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">

    <UserControl.Resources>

        <Style x:Key="HeaderTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="ModelPillStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- User bubble -->
        <Style x:Key="UserBubbleStyle" TargetType="Border">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="CornerRadius" Value="12,12,2,12"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="MaxWidth" Value="260"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="32,2,0,2"/>
        </Style>

        <!-- Code block inside user bubble -->
        <Style x:Key="CodeBubbleStyle" TargetType="Border">
            <Setter Property="Background" Value="#1e2638"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MaxWidth" Value="280"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="16,2,0,2"/>
        </Style>

        <!-- AI bubble -->
        <Style x:Key="AiBubbleStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12,12,12,2"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="MaxWidth" Value="280"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,2,32,2"/>
        </Style>

        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="AcceptsReturn" Value="False"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="MaxHeight" Value="80"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Chat history -->
            <RowDefinition Height="Auto"/>  <!-- Input area -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <DockPanel LastChildFill="False">

                <!-- Avatar + Title -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Border Width="22" Height="22" CornerRadius="11"
                            Background="#0078D4" Margin="0,0,7,0">
                        <TextBlock Text="AI" FontSize="9" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="CodeLens AI" Style="{StaticResource HeaderTitleStyle}"/>
                </StackPanel>

                <!-- Right side: model pill + settings -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Border Style="{StaticResource ModelPillStyle}" Margin="0,0,6,0">
                        <TextBlock x:Name="TxtModelName"
                                   Text="—"
                                   FontSize="10"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="100"/>
                    </Border>
                    <Button x:Name="BtnSettings"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="LLM Settings (Tools → Options → CodeLens AI)"
                            Click="BtnSettings_Click">
                        <TextBlock Text="⚙" FontSize="13"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                    </Button>
                    <Button x:Name="BtnClearAll"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Clear conversation"
                            Click="BtnClearAll_Click"
                            Margin="2,0,0,0">
                        <TextBlock Text="↺" FontSize="13"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Chat history ── -->
        <ScrollViewer x:Name="ChatScroller"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="10,8">
            <StackPanel x:Name="ChatPanel" Orientation="Vertical">

                <!-- Welcome message (shown when empty) -->
                <StackPanel x:Name="WelcomePanel" HorizontalAlignment="Center" Margin="0,24,0,0">
                    <Border Width="44" Height="44" CornerRadius="22"
                            Background="#0078D4" HorizontalAlignment="Center"
                            Margin="0,0,0,10">
                        <TextBlock Text="AI" FontSize="15" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="CodeLens AI"
                               FontSize="14" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Kodu seçin, sorunuzu yazın."
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Input area ── -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="0,1,0,0"
                Padding="8,8,8,8">
            <StackPanel Orientation="Vertical">

                <!-- Code preview (shown when code is loaded) -->
                <Border x:Name="CodePreviewBorder"
                        Background="#1e2638"
                        CornerRadius="6"
                        Padding="8,5"
                        Margin="0,0,0,6"
                        Visibility="Collapsed">
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource IconButtonStyle}"
                                Click="BtnClearCode_Click"
                                Margin="4,0,0,0"
                                ToolTip="Remove code">
                            <TextBlock Text="✕" FontSize="10" Foreground="#80c8ff"/>
                        </Button>
                        <TextBlock x:Name="TxtCodePreview"
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="10"
                                   Foreground="#80c8ff"
                                   TextTrimming="CharacterEllipsis"
                                   MaxHeight="36"
                                   TextWrapping="NoWrap"/>
                    </DockPanel>
                </Border>

                <!-- Message input row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,6,0">
                        <TextBox x:Name="TxtUserMessage"
                                 Style="{StaticResource InputBoxStyle}"
                                 KeyDown="TxtUserMessage_KeyDown"
                                 TextChanged="TxtUserMessage_TextChanged"/>
                        <TextBlock x:Name="PhUserMessage"
                                   Text="Sorunuzu yazın… (Ctrl+Enter)"
                                   FontSize="12"
                                   FontStyle="Italic"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   Margin="9,7,0,0"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Top"/>
                    </Grid>

                    <Button x:Name="BtnSend"
                            Grid.Column="1"
                            Style="{StaticResource SendButtonStyle}"
                            Click="BtnSend_Click"
                            ToolTip="Send (Ctrl+Enter)">
                        <TextBlock Text="↑" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Button>
                </Grid>

                <!-- Typing indicator + cancel -->
                <Grid x:Name="TypingRow" Visibility="Collapsed" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="60" Height="3"
                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatus"
                                   Text="Yanıt bekleniyor…"
                                   FontSize="10"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button x:Name="BtnCancel"
                            Grid.Column="1"
                            Style="{StaticResource IconButtonStyle}"
                            Click="BtnCancel_Click"
                            ToolTip="Cancel">
                        <TextBlock Text="✕ İptal" FontSize="10"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                    </Button>
                </Grid>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
