<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011"
                 xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Id="CodeLensAI.a1b2c3d4-e5f6-7890-abcd-ef1234567890"
              Version="1.0.0"
              Language="en-US"
              Publisher="CodeLensAI Team" />
    <DisplayName>CodeLens AI — Local LLM Code Assistant</DisplayName>
    <Description xml:space="preserve">
      Connect to your local LLM (Ollama, LM Studio, or any OpenAI-compatible endpoint),
      select code in the editor, describe your problem, and get instant AI-powered analysis
      and suggestions — all without leaving Visual Studio.
    </Description>
    <MoreInfo>https://github.com/your-org/CodeLensAI</MoreInfo>
    <License>LICENSE.txt</License>
    <ReleaseNotes>Initial release — v1.0.0</ReleaseNotes>
    <Icon>Resources\icon.png</Icon>
    <PreviewImage>Resources\preview.png</PreviewImage>
    <Tags>AI, LLM, Ollama, code analysis, productivity, local AI</Tags>
    <GettingStartedGuide>https://github.com/your-org/CodeLensAI#getting-started</GettingStartedGuide>
  </Metadata>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Community" Version="[17.0,)" />
    <InstallationTarget Id="Microsoft.VisualStudio.Professional" Version="[17.0,)" />
    <InstallationTarget Id="Microsoft.VisualStudio.Enterprise" Version="[17.0,)" />
  </Installation>
  <Dependencies>
    <Dependency Id="Microsoft.Framework.NDP"
                DisplayName=".NET Framework 4.7.2 or higher"
                Version="[4.7.2,)" />
  </Dependencies>
  <Prerequisites>
    <Prerequisite Id="Microsoft.VisualStudio.Component.CoreEditor"
                  Version="[17.0,)"
                  DisplayName="Visual Studio core editor" />
  </Prerequisites>
  <Assets>
    <Asset Type="Microsoft.VisualStudio.VsPackage"
           d:Source="Project"
           d:ProjectName="%CurrentProject%"
           Path="|CodeLensAI;PkgdefProjectOutputGroup|" />
    <Asset Type="Microsoft.VisualStudio.MefComponent"
           d:Source="Project"
           d:ProjectName="%CurrentProject%"
           Path="|CodeLensAI|" />
  </Assets>
</PackageManifest>
